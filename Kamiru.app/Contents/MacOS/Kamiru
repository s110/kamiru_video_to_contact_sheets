#!/bin/bash
# Ejecutable de Kamiru.app — se lanza al hacer DOBLE CLIC en la app (sin que
# aparezca ninguna terminal). Prepara el entorno la primera vez y abre la app.

HERE="$(cd "$(dirname "$0")" && pwd)"           # …/Kamiru.app/Contents/MacOS
# Kamiru.app vive en la carpeta del proyecto: subimos hasta ella.
PROJECT="$(cd "$HERE/../../.." && pwd)"
cd "$PROJECT" || exit 1

LOG="$PROJECT/.venv/kamiru.log"

alert() {  # alert "titulo" "mensaje"
  /usr/bin/osascript -e "display alert \"$1\" message \"$2\"" >/dev/null 2>&1 || true
}

# Elige un Python 3 con Tk moderno (>= 8.6). En macOS el Tk del sistema (8.5)
# dibuja la ventana en blanco, así que se prefiere el de python.org.
pick_python() {
  local cands=() p w
  for p in /Library/Frameworks/Python.framework/Versions/*/bin/python3; do
    [ -x "$p" ] && cands+=("$p")
  done
  for name in python3.13 python3.12 python3.11 python3.10 python3; do
    w="$(command -v "$name" 2>/dev/null || true)"
    [ -n "$w" ] && cands+=("$w")
  done
  for p in "${cands[@]}"; do
    if "$p" -c 'import tkinter,sys; sys.exit(0 if tkinter.TkVersion>=8.6 else 1)' >/dev/null 2>&1; then
      echo "$p"; return 0
    fi
  done
  for p in "${cands[@]}"; do
    if "$p" -c 'import tkinter' >/dev/null 2>&1; then echo "$p"; return 0; fi
  done
  return 1
}

venv_ok() {
  [ -f ".venv/.deps_ok" ] && \
    .venv/bin/python -c 'import tkinter,sys; sys.exit(0 if tkinter.TkVersion>=8.6 else 1)' >/dev/null 2>&1
}

# Preparación (solo si hace falta): crear entorno e instalar dependencias.
if ! venv_ok; then
  /usr/bin/osascript -e 'display dialog "Preparando Kamiru por primera vez. Puede tardar 1–2 minutos. Pulsa Aceptar y espera a que se abra la ventana." buttons {"Aceptar"} default button 1 with icon note giving up after 12' >/dev/null 2>&1 || true

  PYBIN="$(pick_python || true)"
  if [ -z "$PYBIN" ]; then
    alert "Falta Python" "Instala Python 3 desde https://www.python.org/downloads/ y vuelve a abrir Kamiru."
    exit 1
  fi

  # Si el entorno existente usa un Tk viejo, se recrea con el Python bueno.
  if [ -d ".venv" ] && ! .venv/bin/python -c 'import tkinter,sys; sys.exit(0 if tkinter.TkVersion>=8.6 else 1)' >/dev/null 2>&1; then
    rm -rf .venv
  fi
  if [ ! -d ".venv" ]; then
    "$PYBIN" -m venv .venv || { alert "Error" "No se pudo crear el entorno de Python."; exit 1; }
    rm -f .venv/.deps_ok
  fi
  mkdir -p "$(dirname "$LOG")"
  {
    ./.venv/bin/python -m pip install --upgrade pip
    ./.venv/bin/python -m pip install -r requirements.txt
  } >"$LOG" 2>&1
  if [ $? -ne 0 ]; then
    alert "No se pudo preparar Kamiru" "Falló la instalación de dependencias. Revisa el archivo .venv/kamiru.log dentro de la carpeta del proyecto."
    exit 1
  fi
  touch .venv/.deps_ok
fi

# Abre la app (reemplaza este proceso; no aparece ninguna terminal).
exec ./.venv/bin/python -m kamiru
